# App configuration
PORT=5000
NODE_ENV=development

# Database configuration (PostgreSQL connection string)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ecosphere?schema=public"

# Authentication secret for JWT signing (use a strong, random string in production)
JWT_SECRET="your_jwt_secret_key_here_min_8_chars"
JWT_EXPIRES_IN="1d"

# CORS origin (frontend URL, e.g. http://localhost:3000)
CORS_ORIGIN="http://localhost:3000"
